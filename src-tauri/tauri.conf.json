{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BuildPredict",
  "mainBinaryName": "buildpredict",
  "version": "0.2.0",
  "identifier": "com.endergamershard.buildpredict",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "BuildPredict — PC Stats & Frame Predictor",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.bestbuy.com https://api.retailerapi.com ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "PC stats and frame predictor",
    "longDescription": "PCPartPicker-style System Builder with gaming FPS and coding workload estimates.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
