{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default BuildPredict permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.bestbuy.com/**" },
        { "url": "https://api.retailerapi.com/**" }
      ]
    }
  ]
}
